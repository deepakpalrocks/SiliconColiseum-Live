# === LLM Provider (Cerebras) ===
# Get yours at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=csk_your-cerebras-api-key-here

# Models (optional - defaults shown)
TRADE_MODEL=llama3.1-8b
SENTIMENT_MODEL=llama3.1-8b

# Shared wallet private key for executing trades on Arbitrum One
WALLET_PRIVATE_KEY=your-private-key-here

# Arbitrum One RPC URL (use Alchemy/Infura free tier, not public RPC)
RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Server config
PORT=3001
CRON_INTERVAL_MINUTES=15

# Set to "false" if using external cron (e.g. Render free tier + cron-job.org)
USE_INTERNAL_CRON=true
